#!/usr/bin/env bash

set -euo pipefail

: "${INSTALL_DIRECTORY:?INSTALL_DIRECTORY is not set}"
: "${DOTFILES_DIRECTORY:?DOTFILES_DIRECTORY is not set}"

CONFIGS=(
  git
  keyd
  ghostty
  zsh
  starship
  nvim
  hypr
  waybar
  uwsm
)

cd "$DOTFILES_DIRECTORY"

for config in "${CONFIGS[@]}"; do
  script="$INSTALL_DIRECTORY/dotfiles/$config"

  if [[ ! -f "$script" ]]; then
    echo "⚠️  Skipping $config (missing: $script)" >&2
    continue
  fi

  echo "configuring dotfiles for $config"
  source "$script"
done
