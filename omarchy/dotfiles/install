#!/usr/bin/env bash

set -eu

DOTFILES_DIRECTORY="$HOME/dotfiles"
INSTALL_DIRECTORY="$DOTFILES_DIRECTORY/omarchy"

cd "$DOTFILES_DIRECTORY"

CONFIGS=(
  git
  keyd
  ghostty
  bash
  starship
  nvim
  hypr
  waybar
  uwsm
  mise
)

for config in "${CONFIGS[@]}"; do
  script="$INSTALL_DIRECTORY/dotfiles/$config"

  if [[ ! -f "$script" ]]; then
    echo "⚠️  Skipping $config (missing: $script)" >&2
    continue
  fi

  echo "configuring dotfiles for $config"
  source "$script"
done
