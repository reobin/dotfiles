#!/usr/bin/env bash

set -eu

DOTFILES_DIRECTORY="$HOME/dotfiles"
INSTALL_DIRECTORY="$DOTFILES_DIRECTORY/omarchy"

cd "$INSTALL_DIRECTORY"

APPS=(
  stow
  pnpm
  keyd
  helium-browser
  slack-desktop
  telegram-desktop
  openvpn
  notion-app-electron
  bruno
  aws-cli-v2
  bind
  witr
  turso-cli
  wrangler
  hyprdynamicmonitors
  git-wt
  opencode
  ocv
  claude
  tailscale
  sheets
  valkey
  bun
  wl-clipboard-x11
  proton-authenticator
)

cd "$INSTALL_DIRECTORY"

for app in "${APPS[@]}"; do
  script="$INSTALL_DIRECTORY/software/$app"

  if [[ ! -f "$script" ]]; then
    echo "⚠️  Skipping $app (missing: $script)" >&2
    continue
  fi

  echo "installing $app"
  source "$script"
done
