#!/bin/sh

sudo pacman -S --noconfirm --needed syncthing
systemctl --user enable --now syncthing.service

# Wait for syncthing to generate its initial config
while ! syncthing cli config version get >/dev/null 2>&1; do
  sleep 1
done

# Add ~/Documents/notes/ as a shared folder (skip if already exists)
if ! syncthing cli config folders get --id notes >/dev/null 2>&1; then
  mkdir -p ~/Documents/notes
  syncthing cli config folders add --id notes --label notes --path ~/Documents/notes/
fi
