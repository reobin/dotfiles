[alias]
	ca = commit --amend --no-edit
	p = push
	pl = pull
	cp = cherry-pick
	f = fetch
	r = rebase
	rt = reset
	rts = reset --soft
	rth = reset --hard
	ri = "!f() { git rebase -i HEAD~$1; }; f"
	rir = rebase -i --root
	c = commit
	b = branch
	co = checkout
	a = add .
	s = status
	sh = stash
	shp = stash pop
	shd = stash drop
	l = log
	bc = !"$HOME/.config/git/scripts/branch-cleanup"
[core]
	editor = nvim
[wt]
	copyignored = true
	copyuntracked = true
	copymodified = true
[sequence]
	editor = nvim
[diff]
	tool = nvimdiff
[merge]
	tool = nvimdiff
[user]
	name = Robin Gagnon
	email = me@reobin.dev
