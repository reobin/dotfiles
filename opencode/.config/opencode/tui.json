{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "olive-crt",
  "vim_system_clipboard_register": true,
  "keybinds": {
    "leader": "ctrl+o",
    "input_force_submit": "ctrl+return",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "messages_first": "ctrl+a",
    "messages_last": "ctrl+e"
  }
}
