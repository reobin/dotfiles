{
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "bash '/home/reobin/.claude/hooks/herdr-agent-state.sh' blocked",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash '/home/reobin/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash '/home/reobin/.claude/hooks/herdr-agent-state.sh' release",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/home/reobin/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash '/home/reobin/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash '/home/reobin/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "bash ~/.claude/statusline-command.sh",
    "type": "command"
  },
  "theme": "auto"
}
