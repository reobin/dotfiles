{
  "permissions": {
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "session_id=$(jq -r '.session_id // \"default\"'); cp \"/tmp/claude-statusline-total-$session_id\" \"/tmp/claude-statusline-offset-$session_id\" 2>/dev/null; true"
          }
        ]
      }
    ]
  }
}
