#!/bin/sh

active_profile=""

active_unit=$(systemctl list-units --type=service --state=active --no-legend 2>/dev/null | awk '$1 ~ /vpn/ {print $1}' | while read -r unit; do
  ts=$(systemctl show -p ActiveEnterTimestampMonotonic --value "$unit" 2>/dev/null)
  echo "$ts $unit"
done | awk '{if ($1+0 > max) {max=$1; unit=$2}} END {print unit}')

if [ -n "$active_unit" ]; then
  active_profile=${active_unit#openvpn-client@}
  active_profile=${active_profile%.service}
fi

if [ -n "$active_profile" ]; then
  echo '{"text":"’ĆŻ vpn ('$active_profile')","class":"vpn-on"}'
fi
