#!/usr/bin/env bash

set -eu

# Keep this Mac awake while plugged in. Closed-lid reliability still depends on
# Amphetamine's closed-display mode helper, which is configured separately.

# Disable the accented character popup when holding a key.
defaults write -g ApplePressAndHoldEnabled -bool false

# Make key repeat feel faster.
defaults write -g InitialKeyRepeat -int 20
defaults write -g KeyRepeat -int 1

# Make Dock autohide feel instant.
defaults write com.apple.dock autohide-time-modifier -int 0
defaults write com.apple.Dock autohide-delay -float 0.0001
killall Dock

# Keep the machine awake on AC power, but still let the displays blank on
# idle (~2 min). Closed-lid awake behavior still depends on Amphetamine, while
# battery power keeps a normal sleep timeout to avoid draining in a bag.
sudo pmset -c sleep 0
sudo pmset -b sleep 10
sudo pmset -a displaysleep 2
sudo pmset -a powernap 0
sudo pmset -a tcpkeepalive 1
sudo pmset -c standby 0
sudo pmset -c womp 1
