{
  "manifest_version": 3,
  "name": "Alt-Tab Switcher",
  "version": "1.0.0",
  "description": "Switch tabs with Alt+J and Alt+K",
  "commands": {
    "next-tab": {
      "suggested_key": {
        "default": "Alt+J"
      },
      "description": "Next tab"
    },
    "prev-tab": {
      "suggested_key": {
        "default": "Alt+K"
      },
      "description": "Previous tab"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs"]
}
